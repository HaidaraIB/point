# محتوى ملف GoogleService-Info.plist كاملاً (XML) من Firebase Console لمشروع iOS (Bundle: com.point.agency)
GOOGLE_SERVICE_INFO_PLIST=

SUPABASE_URL=
SUPABASE_ANON_KEY=
