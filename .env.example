# انسخ هذا الملف إلى .env واملأ القيم:  cp .env.example .env
# البناء يتطلب وجود .env في جذر المشروع.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BASE_URL=

# Firebase Project ID (لرابط إرسال FCM في FireStoreServices)
FIREBASE_PROJECT_ID=

# Firebase - Web
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_MEASUREMENT_ID=
FIREBASE_WEB_MESSAGING_SENDER_ID=
# مفتاح VAPID (Web Push) — من Firebase Console > Cloud Messaging > Web Push certificates
FIREBASE_WEB_VAPID_KEY=

# Firebase - Android
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=
FIREBASE_ANDROID_PROJECT_ID=
FIREBASE_ANDROID_STORAGE_BUCKET=
FIREBASE_ANDROID_MESSAGING_SENDER_ID=

# Firebase - iOS
FIREBASE_IOS_API_KEY=
FIREBASE_IOS_APP_ID=
FIREBASE_IOS_PROJECT_ID=
FIREBASE_IOS_STORAGE_BUCKET=
FIREBASE_IOS_MESSAGING_SENDER_ID=
FIREBASE_IOS_BUNDLE_ID=

# كلمة مرور الحساب الاختباري point@accountholder.app (للتطوير فقط؛ اتركه فارغاً في الإنتاج)
TEST_ACCOUNTHOLDER_PASSWORD=

# Google Service Account: JSON كامل كسطر واحد (استبدل \n بمسافة أو ضع المفتاح الخاص في سطر واحد)
# أو استخدم GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=

